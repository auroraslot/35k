你的代码 vs 简化版

  核心改动：把两个 while 合并成一个，指针越界时当作 0 处理。

  class Solution {
      public String addStrings(String num1, String num2) {
          int p1 = num1.length() - 1;
          int p2 = num2.length() - 1;
          int carry = 0; // 进位（用 int 代替 boolean，直接参与计算）
          StringBuilder result = new StringBuilder();

          // 只要还有数字没处理完，或者还有进位
          while (p1 >= 0 || p2 >= 0 || carry > 0) {
              int n1 = p1 >= 0 ? num1.charAt(p1) - '0' : 0; // 越界当0
              int n2 = p2 >= 0 ? num2.charAt(p2) - '0' : 0; // 越界当0

              int sum = n1 + n2 + carry;
              carry = sum / 10;           // 进位：10以上就是1
              result.append(sum % 10);    // 个位数字

              p1--;
              p2--;
          }

          return result.reverse().toString();
      }
  }

